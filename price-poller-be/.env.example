# Server Configuration
PORT=3001
WS_PORT=3002
NODE_ENV=production

# Database Configuration (Neon PostgreSQL or local)
DB_USER=postgres
DB_HOST=localhost
DB_NAME=neondb
DB_PASSWORD=your_password_here
DB_PORT=5432
DB_SSL=false

# Redis Configuration (localhost for dev, redis for docker)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Optional: Binance WebSocket URL (if needed to override)
# BINANCE_WS_URL=wss://stream.binance.com:9443/ws
