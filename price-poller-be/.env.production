# Production Environment Variables for DigitalOcean
# IMPORTANT: Update these values with your actual production credentials

# Server Configuration
PORT=3001
WS_PORT=3002
NODE_ENV=production

# Database Configuration (Local PostgreSQL with TimescaleDB)
DB_USER=tradinguser
DB_HOST=postgres
DB_NAME=trading_db
DB_PASSWORD=Trading@2024!Secure
DB_PORT=5432
DB_SSL=false

# Redis Configuration (Running on same instance)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# JWT Configuration (Generate a strong secret)
JWT_SECRET=your_production_jwt_secret_min_32_chars_long

# CORS Configuration (Update with your Vercel frontend URL)
CORS_ORIGIN=https://your-app.vercel.app

# Binance WebSocket URL
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
